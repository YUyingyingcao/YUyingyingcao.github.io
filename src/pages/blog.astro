---
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((post, index) => {
    const rawText = post.body
      .replace(/```[\s\S]*?```/g, "")
      .replace(/<[^>]+>/g, "")
      .replace(/[#>*_\-[\]()`~]/g, "")
      .trim();
    const cjk = rawText.match(/[\u4e00-\u9fff]/g)?.length ?? 0;
    const words = rawText.replace(/[\u4e00-\u9fff]/g, " ").match(/[A-Za-z0-9]+/g)?.length ?? 0;
    const wordCount = cjk + words;

    return {
      ...post,
      index,
      wordCount,
      readingMinutes: Math.max(1, Math.ceil(wordCount / 420)),
      mood: post.data.mood ?? "雪日手札",
      cover: post.data.cover ?? `/assets/blog-covers/${(index % 11) + 1}.png`,
    };
  });

const formatter = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
});
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Blog | Yunity</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <main class="page-shell blog-page" data-pagefind-body>
      <section class="page-hero">
        <a class="back-link" href="/">← 回到初雪</a>
        <p class="page-kicker">Snow Notebook</p>
        <h1>手札</h1>
        <p>把教程、日记和突然冒出来的想法都收进这里。窗外下雪的时候，适合慢慢读。</p>
      </section>

      <section class="blog-search-panel" aria-label="站内搜索" data-pagefind-ignore>
        <div class="blog-search-panel__copy">
          <span>Search</span>
          <h2>翻找雪里的字</h2>
          <p>关键词会先走 Pagefind 静态索引；预览时索引没加载成功，也会自动用当前文章列表兜底。</p>
        </div>
        <label class="blog-search-box">
          <span>关键词</span>
          <input type="search" data-blog-search placeholder="输入标题、标签或一句描述..." autocomplete="off" />
        </label>
        <div class="blog-search-results" data-blog-search-results aria-live="polite"></div>
      </section>

      <section class="post-timeline" aria-label="文章列表">
        {posts.map((post, index) => (
          <article class="post-timeline-item">
            <div class="timeline-date">
              <time datetime={post.data.pubDate.toISOString()}>{formatter.format(post.data.pubDate)}</time>
              <span>{post.readingMinutes} min read</span>
            </div>
            <a class="post-row" href={`/blog/${post.id}/`} aria-label={`阅读 ${post.data.title}`}>
              <div class={`post-cover-card post-cover-card--${(index % 3) + 1}`} aria-hidden="true">
                <img src={post.cover} alt="" loading="lazy" />
                <span>{String(index + 1).padStart(2, "0")}</span>
                <strong>{post.mood}</strong>
                <em>{post.data.tags[0] ?? "note"}</em>
              </div>
              <div class="post-row__body">
                <div class="post-meta-row">
                  <time datetime={post.data.pubDate.toISOString()}>发布 {formatter.format(post.data.pubDate)}</time>
                  <span>{post.wordCount.toLocaleString("zh-CN")} 字</span>
                  <span>{post.readingMinutes} 分钟</span>
                </div>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                <div class="tag-row">
                  {post.data.tags.map((tag) => <span>#{tag}</span>)}
                </div>
              </div>
            </a>
          </article>
        ))}
      </section>
    </main>
    <script>
      window.addEventListener("DOMContentLoaded", () => {
        const input = document.querySelector("[data-blog-search]");
        const results = document.querySelector("[data-blog-search-results]");
        let pagefindReady;
        let searchTimer = 0;

        const escapeHtml = (value) =>
          value.replace(/[&<>"']/g, (char) => ({
            "&": "&amp;",
            "<": "&lt;",
            ">": "&gt;",
            '"': "&quot;",
            "'": "&#039;",
          })[char] ?? char);

        const renderState = (message) => {
          if (!results) return;
          results.innerHTML = `<p class="blog-search-empty">${message}</p>`;
        };

        const loadPagefind = async () => {
          if (!pagefindReady) {
            const importRuntime = new Function("path", "return import(path)");
            pagefindReady = importRuntime("/pagefind/pagefind.js").then(async (pagefind) => {
              await pagefind.options({ excerptLength: 18 });
              return pagefind;
            });
          }
          return pagefindReady;
        };

        const fallbackLocalSearch = (query) => {
          const lowerQuery = query.toLowerCase();
          const matches = Array.from(document.querySelectorAll(".post-row"))
            .map((card) => ({
              href: card.getAttribute("href") ?? "#",
              title: card.querySelector("h2")?.textContent?.trim() ?? "Untitled",
              excerpt: card.querySelector("p")?.textContent?.trim() ?? "",
              text: card.textContent?.toLowerCase() ?? "",
            }))
            .filter((item) => item.text.includes(lowerQuery))
            .slice(0, 5);

          if (!matches.length) {
            renderState("这片雪里暂时没有找到。");
            return;
          }

          if (!results) return;
          results.innerHTML = matches.map((item) => `
            <a class="blog-search-result" href="${item.href}">
              <strong>${escapeHtml(item.title)}</strong>
              <span>${escapeHtml(item.excerpt)}</span>
            </a>
          `).join("");
        };

        input?.addEventListener("input", () => {
          window.clearTimeout(searchTimer);
          const query = input.value.trim();
          if (!query) {
            if (results) results.innerHTML = "";
            return;
          }

          searchTimer = window.setTimeout(async () => {
            renderState("正在翻页...");
            try {
              const pagefind = await loadPagefind();
              const search = await pagefind.search(query);
              const data = await Promise.all(search.results.slice(0, 5).map((result) => result.data()));

              if (!data.length) {
                renderState("这片雪里暂时没有找到。");
                return;
              }

              if (!results) return;
              results.innerHTML = data.map((item) => `
                <a class="blog-search-result" href="${item.url}">
                  <strong>${escapeHtml(item.meta.title || "Untitled")}</strong>
                  <span>${item.excerpt || ""}</span>
                </a>
              `).join("");
            } catch {
              fallbackLocalSearch(query);
            }
          }, 180);
        });
      });
    </script>
    <script src="/scripts/capsule-nav.js" defer></script>
    <script src="/scripts/ambient-snow.js" defer></script>
    <script src="/scripts/snowman-scrollbar.js" defer></script>
    <script src="/scripts/context-menu.js" defer></script>
  </body>
</html>
